<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #000000;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.globbefitnessapp.controller.APPController">

    <top>
        <VBox spacing="10.0" style="-fx-background-color: #141313;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>

            <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Biblioteca Stephen King" textFill="RED" />

            <HBox spacing="10.0">
                <TextField fx:id="txtIdLibro" prefWidth="180.0" promptText="Introduce el ID del libro" style="-fx-background-color: #1A1818; -fx-text-fill: red; -fx-prompt-text-fill: #aa4444; -fx-border-color: red;" />

                <Button fx:id="btnImportar" style="-fx-background-color: #1A1818; -fx-border-color: red; -fx-border-width: 1;" text="Importar libros" textFill="RED" />

                <Button fx:id="btnBuscar" style="-fx-background-color: #1A1818; -fx-border-color: red; -fx-border-width: 1;" text="Buscar libro" textFill="RED" />

                <Button fx:id="btnFavorito" style="-fx-background-color: #1A1818; -fx-border-color: red; -fx-border-width: 1;" text="Añadir favorito" textFill="RED" />

                <Button fx:id="btnExportar" style="-fx-background-color: #1A1818; -fx-border-color: red; -fx-border-width: 1;" text="Exportar favoritos" textFill="RED" />

                <Button fx:id="btnImportarFav" style="-fx-background-color: #1A1818; -fx-border-color: red; -fx-border-width: 1;" text="Importar favoritos" textFill="RED" />
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="10.0" style="-fx-background-color: #000000;">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="10.0" />
            </padding>

            <TableView fx:id="tablaLibros" prefHeight="320.0" prefWidth="850.0" style="-fx-base: #141313;                               -fx-control-inner-background: #141313;                               -fx-background-color: #141313;                               -fx-table-cell-border-color: #550000;                               -fx-selection-bar: #660000;                               -fx-selection-bar-non-focused: #330000;">

                <columns>
                    <TableColumn fx:id="colId" prefWidth="80.0" text="ID" />
                    <TableColumn fx:id="colTitle" prefWidth="300.0" text="Título" />
                    <TableColumn fx:id="colYear" prefWidth="100.0" text="Año" />
                    <TableColumn fx:id="colPublisher" prefWidth="200.0" text="Editorial" />
                    <TableColumn fx:id="colPages" prefWidth="170.0" text="Páginas" />
                </columns>
            </TableView>

            <Label style="-fx-font-size: 14px; -fx-font-weight: bold;" text="Información del libro / Favoritos" textFill="RED" />

            <TextArea fx:id="txtAreaInfo" editable="false" prefHeight="150.0" style="-fx-control-inner-background: #0a0a0a;                              -fx-background-color: #0a0a0a;                              -fx-text-fill: red;                              -fx-highlight-fill: #660000;                              -fx-highlight-text-fill: white;                              -fx-border-color: red;" wrapText="true" />
        </VBox>
    </center>

</BorderPane>
